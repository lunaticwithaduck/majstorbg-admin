# GitHub Packages PAT with read:packages — required to install @lunaticwithaduck/* packages.
# Pull from majstorbg-backend/.env or generate at https://github.com/settings/tokens.
NODE_AUTH_TOKEN=

# Backend API base URL the admin RTK Query client targets.
# Local docker BE:  http://localhost:3000
# Staging:          https://majstorbg-backend-staging.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:3000

# App environment label (development|staging|production).
NEXT_PUBLIC_APP_ENV=development
